PORT=3000

# Keep this the SAME across every deploy — changing it invalidates login sessions.
JWT_SECRET=change-this-to-a-long-random-string

# Separate from JWT_SECRET so password hashes stay valid even if JWT rotates.
# PASSWORD_PEPPER=another-long-random-string

# Legacy bootstrap hint only — create staff accounts at /staff/register
ADMIN_PASSWORD=pauadmin

# Auto-restore campus operations login after Render redeploys (recommended for production)
# BOOTSTRAP_ADMIN_EMAIL=ops@pau.edu.ng
# BOOTSTRAP_ADMIN_PASSWORD=your-secure-password
# BOOTSTRAP_ADMIN_NAME=Campus Operations

# Optional: restore demo passengers after redeploy (name:email:password|name2:email2:password2)
# DEMO_PASSENGERS=Maki:maki@pau.edu.ng:demo1234|Marcel:marcel@pau.edu.ng:demo1234

# Or a single demo passenger:
# BOOTSTRAP_PASSENGER_EMAIL=maki@pau.edu.ng
# BOOTSTRAP_PASSENGER_PASSWORD=demo1234
# BOOTSTRAP_PASSENGER_NAME=Maki

# Optional: restore demo drivers after redeploy (name:phone:pin|name2:phone2:pin2)
# DEMO_DRIVERS=Osadu Richard Ogaar:08012345678:1234

# Persistent SQLite path (paid Render disk). Free tier cannot use this — data resets each deploy.
# DATABASE_PATH=/var/data/database.db

# Open staff self-registration at /staff/register (no invite code needed)
# Set to false in production once your team accounts are set up
ADMIN_OPEN_REGISTRATION=true

# Optional alternative: require this invite code instead of open registration
# ADMIN_INVITE_CODE=your-secret-invite-code

# Public URL used in driver welcome SMS (defaults to request host)
# PUBLIC_URL=https://your-domain.com

# SMS on driver assign
# console = log to terminal (default, good for FYP demo)
# termii = https://termii.com
# africastalking = https://africastalking.com
# off = disable SMS entirely
SMS_PROVIDER=console

# After this many minutes waiting, assign nearest available driver (not just FIFO)
WAIT_THRESHOLD_MINUTES=5

# Max passengers per driver batch (pickups before drop-offs)
MAX_BATCH_SIZE=4

# Termii (Nigeria) — https://termii.com
TERMII_API_KEY=your_termii_api_key
# 3–11 chars, no spaces — must be approved in Termii dashboard
TERMII_SENDER_ID=QueueGo
# dnd = transactional (recommended for ride alerts). generic = promotional only.
TERMII_CHANNEL=dnd

# Africa's Talking
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
