PORT=3000
JWT_SECRET=change-this-to-a-long-random-string

# Legacy bootstrap hint only — create staff accounts at /staff/register
ADMIN_PASSWORD=pauadmin

# Open staff self-registration at /staff/register (no invite code needed)
# Set to false in production once your team accounts are set up
ADMIN_OPEN_REGISTRATION=true

# Optional alternative: require this invite code instead of open registration
# ADMIN_INVITE_CODE=your-secret-invite-code

# Public URL used in driver welcome SMS (defaults to request host)
# PUBLIC_URL=https://your-domain.com

# SMS on driver assign
# console = log to terminal (default, good for FYP demo)
# termii = https://termii.com
# africastalking = https://africastalking.com
# off = disable SMS entirely
SMS_PROVIDER=console

# After this many minutes waiting, assign nearest available driver (not just FIFO)
WAIT_THRESHOLD_MINUTES=5

# Max passengers per driver batch (pickups before drop-offs)
MAX_BATCH_SIZE=4

# Termii (Nigeria) — https://termii.com
TERMII_API_KEY=your_termii_api_key
# 3–11 chars, no spaces — must be approved in Termii dashboard
TERMII_SENDER_ID=QueueGo
# dnd = transactional (recommended for ride alerts). generic = promotional only.
TERMII_CHANNEL=dnd

# Africa's Talking
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_africastalking_username
